# --- Solana NFT Marketplace (Devnet) ---
# Copy to `.env` and adjust. NEVER commit a real `.env` with secrets.
# All vars are build-time public values (no private keys here).

# RPC endpoint. Default devnet works but is rate-limited; use a Helius/QuickNode
# devnet URL for reliable WebSocket account subscriptions.
VITE_RPC_URL=https://api.devnet.solana.com

# Optional dedicated WebSocket endpoint. If unset, the RPC URL is reused
# (http -> ws is derived automatically).
VITE_RPC_WS_URL=

# Anchor program ID for the marketplace.
VITE_PROGRAM_ID=6MAZYi6WaiB8ztJuJjoAVkbQDxZxfuQuJR3KfrfZncih

# Solana cluster. The UI forces Devnet and warns on mismatch.
VITE_NETWORK=devnet

# Human-readable marketplace name used as a PDA seed (must match the on-chain config).
VITE_MARKETPLACE_NAME=devnet-marketplace

# Feature flags
# Enable the (roadmap) offers/bids UI scaffold. Off by default — it has NO
# on-chain backing and must not be shipped as if it does.
VITE_FEATURE_OFFERS=false

# Demo mode: seed the UI with self-contained sample listings/NFTs (offline SVG
# art) so the marketplace renders fully populated WITHOUT a wallet or any
# on-chain state. Defaults ON so a fresh install is never an empty screen.
# Set to false to run against live Devnet on-chain data. Never sends transactions.
VITE_DEMO_MODE=true
